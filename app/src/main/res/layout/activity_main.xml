<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="0dp"
        tools:context=".MainActivity">

        <View
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="#212121"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/userName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Nathan G.N. Santos"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="2"
            app:layout_constraintBottom_toBottomOf="@id/topBar"
            app:layout_constraintEnd_toStartOf="@+id/btnMode"
            app:layout_constraintStart_toStartOf="@id/topBar"
            app:layout_constraintTop_toTopOf="@id/topBar" />

        <LinearLayout
            android:id="@+id/containerLanguages"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:background="@drawable/bg_language_group"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_margin="16dp">

            <ImageView
                android:id="@+id/imgCurrentFlag"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/brazil_icon" />

        </LinearLayout>

        <Button
            android:id="@+id/btnMode"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#444444"
            android:text="🌙"
            android:padding="0dp"
            app:cornerRadius="25dp"
            app:layout_constraintBottom_toBottomOf="@id/topBar"
            app:layout_constraintEnd_toStartOf="@id/containerLanguages"
            app:layout_constraintTop_toTopOf="@id/topBar" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/userPhoto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:scaleType="centerCrop"
            android:src="@drawable/luffy_perfil"
            app:layout_constraintStart_toStartOf="@id/topBar"
            app:layout_constraintEnd_toEndOf="@id/topBar"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <TextView
            android:id="@+id/tituloBio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Sobre Mim"
            android:textStyle="bold"
            android:textColor="#333333"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userPhoto" />

        <TextView
            android:id="@+id/bio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:lineSpacingExtra="4dp"
            android:text="Estudante de ADS focado em dominar o ecossistema Android. Atualmente focado em Kotlin e arquitetura mobile..."
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/tituloBio"
            app:layout_constraintTop_toBottomOf="@id/tituloBio" />

        <TextView
            android:id="@+id/tituloSkills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Hard Skills"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/bio"
            app:layout_constraintTop_toBottomOf="@id/bio" />

        <View
            android:id="@+id/badgeKotlin"
            android:layout_width="1dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toBottomOf="@id/tituloSkills"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/sectionEducation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/badgeKotlin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/titleEducation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Education"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/universityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Braz Cubas University Center"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/degreeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Associate Degree in Systems Analysis and Development" />

            <TextView
                android:id="@+id/graduationDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expected Graduation: Dec 2028"
                android:textColor="#666666"
                android:textSize="13sp"
                android:textStyle="italic" />

        </LinearLayout>

        <TextView
            android:id="@+id/projectsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Featured Projects"
            android:textStyle="bold"
            android:textColor="#333333"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sectionEducation" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/projectsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/projectsTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kotlin Interactive Resume App"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Native Android app developed to showcase technical skills."
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnVerCodigo"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="View Source Code" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:background="#212121"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/projectsCard"
        />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="@id/bottomBar"
            app:layout_constraintBottom_toBottomOf="@id/bottomBar"
            app:layout_constraintStart_toStartOf="@id/bottomBar"
            app:layout_constraintEnd_toEndOf="@id/bottomBar">

            <ImageButton
                android:id="@+id/btnWhatsapp"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/whatsapp_icon_black_transparent"/>

            <ImageButton
                android:id="@+id/botaoGitHub"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/icone_github" />

            <Space
                android:layout_width="32dp"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/botaoLinkedIn"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/icone_linkedin" />

            <ImageButton
                android:id="@+id/btnEmail"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:src="@drawable/icone_gmail"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>